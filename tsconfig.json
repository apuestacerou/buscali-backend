{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "typeRoots": ["./conductores-src/types", "./node_modules/@types"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "conductores-src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["conductores-src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
