# Copia este archivo a .env y rellena los valores (nunca subas .env a Git).

# PostgreSQL (obligatorio). Este backend solo usa DATABASE_URL (no DB_HOST/DB_USER/...).
# Ejemplo Neon:
# DATABASE_URL=postgresql://usuario:password@host.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Zona horaria para Sequelize (ej. Colombia)
TIMEZONE=America/Bogota

# JWT (obligatorio en producción: cadena larga y aleatoria)
SECRET_JWT_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio

# Orígenes CORS: una línea, URLs separadas por coma (no uses formato JSON ["..."]).
# Incluye: panel Vite (5173), Expo web (8081), backend mismo (3000), IPs LAN si pruebas desde el móvil.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,http://127.0.0.1:8081

# URL del front para enlaces (recuperación de contraseña, etc.)
FRONTEND_URL=http://localhost:5173

# Opcional: correo para conductores / recuperación (nodemailer)
EMAIL_USER=
EMAIL_PASS=

PORT=3000
NODE_ENV=development
