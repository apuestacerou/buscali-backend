# Conexión a Postgres (Neon). Usar una sola opción: DATABASE_URL o las variables por separado.

# Opción 1: URL completa (recomendado para Neon)
DATABASE_URL=postgresql://usuario:password@host/database?sslmode=require

# Opción 2: Variables por separado
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=neondb
# DB_USER=usuario
# DB_PASSWORD=password

NODE_ENV=development
